{
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(bundle:*)",
      "Bash(cat:*)",
      "Bash(chezmoi:*)",
      "Bash(curl:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(fd:*)",
      "Bash(for:*)",
      "Bash(gh:*)",
      "Bash(ghq:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(gws:*)",
      "Bash(jq:*)",
      "Bash(keyring:*)",
      "Bash(ls:*)",
      "Bash(mise:*)",
      "Bash(mkdir:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pnpm:*)",
      "Bash(ps:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(ruby:*)",
      "Bash(sed:*)",
      "Bash(sqlite3:*)",
      "Bash(tree:*)",
      "Bash(uv:*)",
      "Bash(uvx:*)",
      "Bash(which:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Edit(**)",
      "MultiEdit(**)",
      "Write(**)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__claude_ai_Notion__*",
      "mcp__claude_ai_Slack__*",
      "mcp__gemini-cli__ask-gemini",
      "mcp__github",
      "mcp__github-enterprise-server",
      "mcp__freee-remote",
      "Skill(commit-commands:*)"
    ],
    "deny": [],
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "PreToolUse": [],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"Current time: '$(date +%H:%M:%S%z)'\"}}'",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '[(\"CC [\" + (.cwd // \"\" | split(\"/\") | last) + \"]\"), (.message // \"入力待ちです\")] | @sh' | xargs notify",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs sed -i -e '$a\\'"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs sed -i 's/[[:space:]]*$//'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.bash"
  },
  "enabledPlugins": {
    "freee-mcp@freee-mcp-marketplace": true,
    "commit-commands@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "freee-mcp-marketplace": {
      "source": {
        "source": "github",
        "repo": "freee/freee-mcp"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
